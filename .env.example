# Park-D Environment Variables
# Copy this file to .env.local for local development
# Copy to .env for Docker Compose

# JWT Secret - MUST change in production (use: openssl rand -base64 32)
JWT_SECRET=change-me-in-production-use-a-long-random-string

# Railway/MySQL connection (required by API routes)
DB_HOST=your-railway-mysql-host
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=your-db-name
DB_SSL=true

# Google Maps API (required for map picker + geocoding)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
# Optional: server-side Places API key for location normalization
GOOGLE_PLACES_API_KEY=your-google-places-api-key
# Optional: Google Translation API key (language detection/fallback)
GOOGLE_TRANSLATE_API_KEY=your-google-translate-api-key

# Brevo transactional mail (required for forgot password + security codes + approval emails)
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=no-reply@your-domain.com
BREVO_SENDER_NAME=Park:D
# Optional: override Brevo API endpoint (full URL or base URL)
# BREVO_API_URL=https://api.brevo.com/v3/smtp/email
# Optional: email sender retry/timeout tuning
# BREVO_SEND_RETRY_COUNT=2
# BREVO_SEND_TIMEOUT_MS=15000

# Optional unified URL if you also use another ORM/client
# DATABASE_URL=mysql://user:password@host:3306/database
